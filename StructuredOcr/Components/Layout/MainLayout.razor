@inherits LayoutComponentBase
@using StructuredOcr.Components.Shared

<ConfigLoader />

<BbSidebarProvider DefaultOpen="true" Variant="SidebarVariant.Sidebar">
    <BbSidebar>
        <NavMenu />
        <BbSidebarRail />
    </BbSidebar>
    <BbSidebarInset>
        <header class="flex h-14 items-center gap-2 border-b px-4">
            <BbSidebarTrigger />
            <BbSeparator Class="mr-2 h-4" />
            <span class="text-sm font-medium text-muted-foreground">OCR Benchmark</span>
        </header>
        <main class="flex-1 p-6">
            @Body
        </main>
    </BbSidebarInset>
</BbSidebarProvider>

<BbPortalHost />
<BbToastProvider />
<BbDialogProvider />
